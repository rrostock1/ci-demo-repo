{
  "name": "ci-demo",
  "version": "1.0.0",
  "description": "Demo repo for Week 10: CI/CD in Practice",
  "scripts": {
    "lint":             "eslint src/",
    "lint:fix":         "eslint src/ --fix",
    "test":             "jest --testPathPattern=tests/unit --coverage",
    "test:unit":        "jest --testPathPattern=tests/unit --coverage",
    "test:integration": "jest --testPathPattern=tests/integration --testTimeout=15000",
    "test:all":         "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  },
  "dependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  }
}
